{
    "name": "FreeRTOS + UVM-SystemC Verification",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
    "features": {
        "ghcr.io/devcontainers/features/gcc:1": {
            "version": "11"
        },
        "ghcr.io/devcontainers/features/cmake:1": {
            "version": "3.22"
        }
    },
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y build-essential gcc g++ gdb cmake git python3 python3-pip bc libpthread-stubs0-dev",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extensions-pack"
            ]
        }
    },
    "forwardPorts": [22]
}